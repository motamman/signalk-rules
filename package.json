{
  "name": "signalk-rules",
  "version": "0.1.0-beta.1",
  "description": "Declarative IFTTT-style automation rules for Signal K: IF a path value/expression, WHEN a schedule fires, THEN run an ordered batch of actions. Managed through a rules-table webapp.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "dev": "npm run build && npm run watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-utility",
    "automation",
    "rules",
    "ifttt",
    "trigger",
    "scheduler",
    "cron",
    "rules-engine",
    "marine",
    "typescript"
  ],
  "author": "Maurice Tamman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motamman/signalk-rules.git"
  },
  "homepage": "https://github.com/motamman/signalk-rules#readme",
  "bugs": {
    "url": "https://github.com/motamman/signalk-rules/issues"
  },
  "signalk": {
    "appSupport": "webapp",
    "compatibility": ">=2.13.0",
    "displayName": "Rules"
  },
  "dependencies": {
    "@signalk/server-api": "^2.7.1",
    "json-rules-engine": "^7.3.1",
    "node-cron": "^3.0.3",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/suncalc": "^1.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
